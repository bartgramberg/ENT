# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# Password required to access the public ENT demo.
# Share this with partners and funders alongside the URL.
ENT_ACCESS_PASSWORD=

# --- Alleen nodig voor scripts/ndff-import.mjs, niet voor de app zelf ---
# De app leest de NDFF-laag via geaggregeerde RPC's met de publieke anon-key
# (die staat in data/bronnen.json). Importeren vereist wél schrijfrechten en
# dus de service role key: Supabase → Settings → API → service_role.
# Deze sleutel omzeilt row-level security. Houd 'm lokaal; zet 'm niet in
# Netlify en deel 'm niet.
SUPABASE_URL=https://lopbewmslyfnfsxfxlpj.supabase.co
SUPABASE_SERVICE_KEY=
